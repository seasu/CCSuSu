---
import { siteUrl } from '../lib/readingTime';
const year = new Date().getFullYear();
---

<footer class="border-t border-border bg-surface mt-auto">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-text-muted">
    <p>© {year} CCSuSu — AI 軟體開發日誌</p>
    <div class="flex items-center gap-4">
      <a href="https://github.com/seasu/ccsusu" target="_blank" rel="noopener noreferrer"
         class="hover:text-primary transition-colors">GitHub</a>
      <a href={siteUrl('/sitemap-index.xml')} class="hover:text-primary transition-colors">Sitemap</a>
    </div>
  </div>
</footer>
